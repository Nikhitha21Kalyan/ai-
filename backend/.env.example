# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=True

# Security Keys (Change these in production!)
SECRET_KEY=your_secret_key_change_in_production_12345
JWT_SECRET=your_jwt_secret_key_change_in_production_67890

# MongoDB Configuration
# Local: mongodb://localhost:27017/healthcare
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/healthcare
MONGODB_URI=mongodb://localhost:27017/healthcare

# JWT Configuration
JWT_EXPIRATION_HOURS=24

# Server Configuration
PORT=5000
HOST=0.0.0.0

# Frontend Configuration
FRONTEND_URL=http://localhost:5000

# CORS Configuration
CORS_ORIGINS=*

# Logging
LOG_LEVEL=DEBUG

